# STOCKLAB environment template
# Copy to .env or .env.local and fill the values locally.

# App / deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERCEL_PROJECT_URL=https://vercel.com/haks-finance-lab-s-projects/finance-lab/FTvccBoUFk6QnjxKhAA6TzbQA3Nf

# Platform automation tokens — consumed by `pnpm register:secrets`.
# Vercel: https://vercel.com/account/tokens (full scope on the team).
VERCEL_TOKEN=
# GitHub fine-grained PAT: https://github.com/settings/personal-access-tokens
#   - Repository access: hakslabs/finance_lab only
#   - Permissions: Secrets → Read and write
GITHUB_TOKEN=

# Single Supabase project for dev / preview / production for now
SUPABASE_URL=https://luiaofafdbikmqusurpi.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Cron protection
CRON_SECRET=

# Market / macro data
KRX_API_KEY=
DART_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
NEWSAPI_KEY=
ALPHAVANTAGE_KEY=

# AI / document processing
GEMINI_API_KEY=

# OAuth - deferred; keep placeholders for the final auth pass
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# M1 default ticker policy
# Use top constituents by market cap/weight: KOSPI and S&P 500 first.
M1_DEFAULT_INDEXES=KOSPI,S&P500
M1_DEFAULT_TICKER_SELECTION=market_cap_desc
